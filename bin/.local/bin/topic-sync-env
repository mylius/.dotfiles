#!/usr/bin/env bash
# topic-sync-env - propagate env symlinks to all existing worktrees

set -euo pipefail

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/topic"
CONFIG_FILE="$CONFIG_DIR/env-symlinks.conf"

if [[ ! -f "$CONFIG_FILE" ]]; then
    echo "No env-symlinks.conf found at $CONFIG_FILE"
    exit 1
fi

echo "Syncing env symlinks to all worktrees..."

# Get all worktree paths
git worktree list --porcelain | grep "^worktree " | sed 's/^worktree //' | while read -r worktree_path; do
    echo ""
    echo "==> $worktree_path"

    while IFS= read -r line || [[ -n "$line" ]]; do
        # Skip comments and empty lines
        [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue

        # Parse: source -> target (arrow is " -> ")
        if [[ "$line" =~ ^(.+)[[:space:]]+-\>[[:space:]]+(.+)$ ]]; then
            src="${BASH_REMATCH[1]}"
            dst="${BASH_REMATCH[2]}"
            # Trim whitespace
            src="${src%"${src##*[![:space:]]}"}"
            dst="${dst#"${dst%%[![:space:]]*}"}"

            src_path="$HOME/$src"
            dst_path="$worktree_path/$dst"

            if [[ ! -f "$src_path" ]]; then
                echo "    [skip] $src (source not found)"
                continue
            fi

            if [[ -L "$dst_path" ]]; then
                echo "    [ok] $dst (already symlinked)"
            elif [[ -e "$dst_path" ]]; then
                echo "    [skip] $dst (file exists, not a symlink)"
            else
                mkdir -p "$(dirname "$dst_path")"
                ln -s "$src_path" "$dst_path"
                echo "    [created] $dst -> $src"
            fi
        fi
    done < "$CONFIG_FILE"
done

echo ""
echo "Done!"
