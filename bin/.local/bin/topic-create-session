#!/usr/bin/env bash
# topic-create-session - create tmux session with standard windows for a worktree

set -euo pipefail

WORKTREE_PATH="$1"
SESSION_NAME="$2"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/topic"
CONFIG_FILE="$CONFIG_DIR/topic.toml"

# Allow callers (e.g. `topic -c`) to skip tmux session creation while still
# running env-symlink / hardlink / post_create_commands setup.
: "${TOPIC_SKIP_SESSION:=0}"

# --- Parse topic.toml ---
NVIM_DIR="."
ENV_SRCS=()
ENV_DSTS=()
HARDLINK_DIRS=()
POST_CREATE_CMDS=()

if [[ -f "$CONFIG_FILE" ]]; then
    section=""
    while IFS= read -r line || [[ -n "$line" ]]; do
        # Strip comments and trim
        line="${line%%#*}"
        line="${line#"${line%%[![:space:]]*}"}"
        line="${line%"${line##*[![:space:]]}"}"
        [[ -z "$line" ]] && continue

        # Track array-of-tables section
        if [[ "$line" == "[[env_symlinks]]" ]]; then
            section="env_symlink"
            _src="" ; _dst=""
            continue
        fi

        # Detect which array we're in
        if [[ "$line" =~ ^hardlink_dirs ]]; then
            section="hardlink_dirs"
        elif [[ "$line" =~ ^post_create_commands ]]; then
            section="post_create_commands"
        fi

        # Simple key = value parsing
        if [[ "$line" =~ ^([a-z_]+)[[:space:]]*=[[:space:]]*\"(.+)\"$ ]]; then
            key="${BASH_REMATCH[1]}"
            val="${BASH_REMATCH[2]}"
            case "$key" in
                nvim_dir) NVIM_DIR="$val" ;;
                src) _src="$val" ;;
                dst)
                    _dst="$val"
                    if [[ -n "$_src" ]]; then
                        ENV_SRCS+=("$_src")
                        ENV_DSTS+=("$_dst")
                    fi
                    ;;
            esac
        fi

        # Parse array items (quoted strings inside [...])
        if [[ "$line" =~ ^\"(.+)\",?$ ]]; then
            case "$section" in
                hardlink_dirs) HARDLINK_DIRS+=("${BASH_REMATCH[1]}") ;;
                post_create_commands) POST_CREATE_CMDS+=("${BASH_REMATCH[1]}") ;;
            esac
        fi
    done < "$CONFIG_FILE"
fi

# Determine whether this is a first-time setup (any work to do beyond session)
NEEDS_SETUP=0
for i in "${!ENV_SRCS[@]}"; do
    [[ -f "$HOME/${ENV_SRCS[$i]}" && ! -e "$WORKTREE_PATH/${ENV_DSTS[$i]}" ]] && NEEDS_SETUP=1
done
MAIN_WORKTREE=$(git worktree list --porcelain 2>/dev/null | head -1 | sed 's/^worktree //')
for dir in "${HARDLINK_DIRS[@]}"; do
    [[ -d "$MAIN_WORKTREE/$dir" && ! -d "$WORKTREE_PATH/$dir" ]] && NEEDS_SETUP=1
done
[[ ${#POST_CREATE_CMDS[@]} -gt 0 && ! -f "$WORKTREE_PATH/.wayve/git_merge_base_hash" ]] && NEEDS_SETUP=1

if [[ "$NEEDS_SETUP" == "1" ]]; then
    echo "[topic] Setting up worktree at $WORKTREE_PATH"
fi

# --- Run post-create commands ---
for cmd in "${POST_CREATE_CMDS[@]}"; do
    echo "[topic] Running: $cmd"
    (cd "$WORKTREE_PATH" && eval "$cmd") || true
done

# --- Create env file symlinks ---
for i in "${!ENV_SRCS[@]}"; do
    src_path="$HOME/${ENV_SRCS[$i]}"
    dst_path="$WORKTREE_PATH/${ENV_DSTS[$i]}"
    if [[ -f "$src_path" && ! -e "$dst_path" ]]; then
        echo "[topic] Linking env: ${ENV_DSTS[$i]}"
        mkdir -p "$(dirname "$dst_path")"
        ln -s "$src_path" "$dst_path"
    fi
done

# --- Hard-link copy directories from main worktree ---
for dir in "${HARDLINK_DIRS[@]}"; do
    src="$MAIN_WORKTREE/$dir"
    dst="$WORKTREE_PATH/$dir"
    if [[ -d "$src" && ! -d "$dst" ]]; then
        echo "[topic] Hard-link copying: $dir"
        mkdir -p "$(dirname "$dst")"
        cp -al "$src" "$dst" 2>/dev/null || cp -r "$src" "$dst"
    fi
done

# Skip tmux session creation if requested (e.g. agent-only usage)
if [[ "$TOPIC_SKIP_SESSION" == "1" ]]; then
    exit 0
fi

# Check if session already exists
if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
    if [[ -n "${TMUX:-}" ]]; then
        tmux switch-client -t "$SESSION_NAME"
    else
        tmux attach-session -t "$SESSION_NAME"
    fi
    exit 0
fi

echo "[topic] Creating tmux session: $SESSION_NAME"

# Resolve nvim working directory
NVIM_PATH="$WORKTREE_PATH/$NVIM_DIR"

# Create new session with first window (nvim window starts in NVIM_PATH)
tmux new-session -d -s "$SESSION_NAME" -c "$NVIM_PATH"

# Rename first window and create others
tmux rename-window -t "$SESSION_NAME:1" "nvim"
tmux new-window -t "$SESSION_NAME:2" -c "$WORKTREE_PATH" -n "claude"
tmux new-window -t "$SESSION_NAME:3" -c "$WORKTREE_PATH" -n "codex"
tmux new-window -t "$SESSION_NAME:4" -c "$WORKTREE_PATH" -n "shell"
tmux new-window -t "$SESSION_NAME:5" -c "$WORKTREE_PATH" -n "jump"

# Start apps (nvim launched from its directory so cwd-based search works correctly)
tmux send-keys -t "$SESSION_NAME:1" "nvim ." Enter
tmux send-keys -t "$SESSION_NAME:2" "claude" Enter
tmux send-keys -t "$SESSION_NAME:3" "codex" Enter
# window 4 (shell) stays blank
tmux send-keys -t "$SESSION_NAME:5" "topic-jump '$SESSION_NAME:5'" Enter

# Select nvim window
tmux select-window -t "$SESSION_NAME:1"

# Attach or switch
if [[ -n "${TMUX:-}" ]]; then
    tmux switch-client -t "$SESSION_NAME"
else
    tmux attach-session -t "$SESSION_NAME"
fi
