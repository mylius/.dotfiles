#!/usr/bin/env bash
# topic - unified worktree + tmux workspace command

set -euo pipefail

# Clean up bazel output base for a worktree path
clean_bazel_cache() {
    local worktree_path="$1"
    local cache_dir
    cache_dir=$(dirname "$(bazel info output_base 2>/dev/null)" 2>/dev/null) || return
    [[ ! -d "$cache_dir" ]] && return

    for base in "$cache_dir"/*/; do
        [[ ! -f "$base/DO_NOT_BUILD_HERE" ]] && continue
        if grep -q "$worktree_path" "$base/DO_NOT_BUILD_HERE" 2>/dev/null; then
            local size
            size=$(du -sh "$base" 2>/dev/null | cut -f1)
            echo "  Removing bazel cache ($size): $(basename "$base")"
            rm -rf "$base"
        fi
    done
}

usage() {
    cat <<EOF
Usage: topic [OPTIONS] [branch]

Switch to, create, or remove worktree-based tmux sessions.

Options:
  -c, --create    Create a new worktree and session
  -r, --remove    Remove a worktree and its session (fuzzy finder if no branch)
  -p, --purge     Remove all worktrees whose branches are merged/deleted on remote
  -h, --help      Show this help message

Examples:
  topic                    Fuzzy-select topic to switch to
  topic feature/auth       Switch to existing topic
  topic -c feature/new     Create new topic
  topic -r                 Fuzzy-select topic to remove
  topic -r feature/old     Remove specific topic
  topic -p                 Purge all merged/stale topics
EOF
    exit "${1:-1}"
}

# Parse flags
ACTION="switch"
BRANCH=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -c|--create)
            ACTION="create"
            shift
            ;;
        -r|--remove)
            ACTION="remove"
            shift
            ;;
        -p|--purge)
            ACTION="purge"
            shift
            ;;
        -h|--help)
            usage 0
            ;;
        -*)
            echo "Unknown option: $1"
            usage
            ;;
        *)
            BRANCH="$1"
            shift
            ;;
    esac
done

# Handle remove action
if [[ "$ACTION" == "remove" ]]; then
    if [[ -z "$BRANCH" ]]; then
        # Fast fuzzy finder using git worktree list (instant vs slow wt list)
        BRANCH=$(git worktree list --porcelain 2>/dev/null | \
            grep "^branch" | \
            sed 's|branch refs/heads/||' | \
            grep -v '^main$' | \
            fzf --prompt="Remove topic: " --height=40% --reverse) || exit 0
        [[ -z "$BRANCH" ]] && exit 0
    fi

    SESSION_NAME="${BRANCH//\//-}"

    # Check for uncommitted changes in worktree
    WORKTREE_PATH=$(git worktree list --porcelain 2>/dev/null | \
        awk -v branch="$BRANCH" '/^worktree /{wt=$0} /^branch refs\/heads\//{if($0 == "branch refs/heads/"branch) print wt}' | \
        sed 's/^worktree //')

    DIRTY=""
    if [[ -n "$WORKTREE_PATH" ]]; then
        DIRTY=$(git -C "$WORKTREE_PATH" status --porcelain 2>/dev/null || true)
        if [[ -n "$DIRTY" ]]; then
            echo "Warning: '$BRANCH' has uncommitted changes:"
            git -C "$WORKTREE_PATH" status --short
            echo ""
            read -p "Delete anyway? [y/N] " -n 1 -r
            echo
            [[ ! $REPLY =~ ^[Yy]$ ]] && exit 0
        fi
    fi

    # Kill tmux session first (if exists)
    tmux kill-session -t "$SESSION_NAME" 2>/dev/null || true

    # Clean up bazel cache for this worktree
    [[ -n "$WORKTREE_PATH" ]] && clean_bazel_cache "$WORKTREE_PATH"

    # Remove worktree (force if user confirmed dirty)
    if [[ -n "$DIRTY" ]]; then
        wt remove --force "$BRANCH"
    else
        wt remove "$BRANCH"
    fi
    exit 0
fi

# Handle purge action - remove worktrees for merged/deleted remote branches
if [[ "$ACTION" == "purge" ]]; then
    echo "Fetching remote state..."
    git fetch --prune origin 2>/dev/null

    # Get worktree branches (excluding main)
    WORKTREE_BRANCHES=$(git worktree list --porcelain 2>/dev/null | \
        grep "^branch" | \
        sed 's|branch refs/heads/||' | \
        grep -v '^main$') || true

    if [[ -z "$WORKTREE_BRANCHES" ]]; then
        echo "No topic worktrees found."
        exit 0
    fi

    # Find branches that were pushed and then deleted on remote (likely merged)
    TO_PURGE=()
    WARNINGS=()
    while IFS= read -r branch; do
        [[ -z "$branch" ]] && continue

        # Check if branch had tracking configured (was pushed at some point)
        tracking=$(git config "branch.$branch.remote" 2>/dev/null || true)
        remote_exists=false
        git show-ref --verify --quiet "refs/remotes/origin/$branch" 2>/dev/null && remote_exists=true
        commits_ahead=$(git rev-list origin/main.."$branch" --count 2>/dev/null || echo "0")

        if [[ -n "$tracking" && "$remote_exists" == "false" ]]; then
            # Was pushed, remote branch now gone
            if [[ "$commits_ahead" -eq 0 ]]; then
                TO_PURGE+=("$branch")
            else
                WARNINGS+=("$branch ($commits_ahead unpushed commits)")
            fi
        fi
    done <<< "$WORKTREE_BRANCHES"

    # Show warnings first (not auto-purged)
    if [[ ${#WARNINGS[@]} -gt 0 ]]; then
        echo ""
        echo "Skipped (have unpushed commits):"
        for item in "${WARNINGS[@]}"; do
            echo "  - $item"
        done
    fi

    if [[ ${#TO_PURGE[@]} -gt 0 ]]; then
        echo ""
        echo "Topics to purge (remote deleted, no local changes):"
        for branch in "${TO_PURGE[@]}"; do
            echo "  - $branch"
        done
        echo ""

        read -p "Remove these topics? [y/N] " -n 1 -r
        echo
    fi

    if [[ ${#TO_PURGE[@]} -gt 0 && $REPLY =~ ^[Yy]$ ]]; then
        for branch in "${TO_PURGE[@]}"; do
            SESSION_NAME="${branch//\//-}"

            # Get worktree path before removing
            WT_PATH=$(git worktree list --porcelain 2>/dev/null | \
                awk -v branch="$branch" '/^worktree /{wt=$0} /^branch refs\/heads\//{if($0 == "branch refs/heads/"branch) print wt}' | \
                sed 's/^worktree //')

            echo "Removing $branch..."
            tmux kill-session -t "$SESSION_NAME" 2>/dev/null || true
            [[ -n "$WT_PATH" ]] && clean_bazel_cache "$WT_PATH"
            wt remove "$branch" 2>/dev/null || echo "  (worktree already removed)"
        done
    fi

    # Clean orphaned bazel caches (worktrees already deleted)
    cache_dir=$(dirname "$(bazel info output_base 2>/dev/null)" 2>/dev/null) || true
    if [[ -n "$cache_dir" && -d "$cache_dir" ]]; then
        ORPHANED=()
        ORPHANED_SIZE=0
        for base in "$cache_dir"/*/; do
            [[ ! -f "$base/DO_NOT_BUILD_HERE" ]] && continue
            ws_path=$(head -1 "$base/DO_NOT_BUILD_HERE" 2>/dev/null)
            if [[ -n "$ws_path" && ! -d "$ws_path" ]]; then
                size=$(du -sh "$base" 2>/dev/null | cut -f1)
                ORPHANED+=("$base|$ws_path|$size")
            fi
        done

        if [[ ${#ORPHANED[@]} -gt 0 ]]; then
            echo ""
            echo "Orphaned bazel caches (worktree no longer exists):"
            for entry in "${ORPHANED[@]}"; do
                IFS='|' read -r path ws size <<< "$entry"
                echo "  - $size  $(basename "$ws")"
            done
            echo ""
            read -p "Remove orphaned caches? [y/N] " -n 1 -r
            echo
            if [[ $REPLY =~ ^[Yy]$ ]]; then
                for entry in "${ORPHANED[@]}"; do
                    IFS='|' read -r path ws size <<< "$entry"
                    echo "  Removing $(basename "$ws") ($size)..."
                    rm -rf "$path"
                done
            fi
        fi
    fi

    echo "Done!"
    exit 0
fi

# For switch without branch, use fuzzy finder
if [[ -z "$BRANCH" && "$ACTION" == "switch" ]]; then
    BRANCHES=$(git worktree list --porcelain 2>/dev/null | \
        grep "^branch" | \
        sed 's|branch refs/heads/||')

    # --print-query outputs query on first line, selection on second
    FZF_OUTPUT=$(echo "$BRANCHES" | \
        fzf --prompt="Switch to topic: " --height=40% --reverse --print-query 2>/dev/null) || true

    QUERY=$(echo "$FZF_OUTPUT" | head -1)
    SELECTION=$(echo "$FZF_OUTPUT" | sed -n '2p')

    # Use selection if it exists, otherwise check if query matches an existing branch
    if [[ -n "$SELECTION" ]]; then
        BRANCH="$SELECTION"
    elif [[ -n "$QUERY" ]]; then
        # Check if query matches an existing branch
        if echo "$BRANCHES" | grep -qx "$QUERY"; then
            BRANCH="$QUERY"
        else
            # Query doesn't match any branch - offer to create
            read -p "Topic '$QUERY' not found. Create it? [y/N] " -n 1 -r
            echo
            if [[ $REPLY =~ ^[Yy]$ ]]; then
                BRANCH="$QUERY"
                ACTION="create"
            else
                exit 0
            fi
        fi
    else
        exit 0
    fi
fi

# For create, branch is required
[[ -z "$BRANCH" && "$ACTION" == "create" ]] && usage

# For create action, prefix with username if not already prefixed
if [[ "$ACTION" == "create" ]]; then
    BRANCH_PREFIX="${TOPIC_BRANCH_PREFIX:-$USER}"
    if [[ -n "$BRANCH_PREFIX" && "$BRANCH" != "$BRANCH_PREFIX/"* ]]; then
        BRANCH="$BRANCH_PREFIX/$BRANCH"
    fi
fi

# Sanitize branch name for session naming (same as worktrunk)
SESSION_NAME="${BRANCH//\//-}"

# Use worktrunk to switch/create worktree
# The post-start hook will handle sesh session creation for new worktrees
if [[ "$ACTION" == "create" ]]; then
    # Try to create, fall back to switch if branch exists
    if ! wt switch --create "$BRANCH" 2>/dev/null; then
        echo "Branch exists, switching to it..."
        wt switch "$BRANCH"
    fi
else
    wt switch "$BRANCH"
fi

# If inside tmux, switch to the session
if [[ -n "${TMUX:-}" ]]; then
    tmux switch-client -t "$SESSION_NAME" 2>/dev/null || true
fi
